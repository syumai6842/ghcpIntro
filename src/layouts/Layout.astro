---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "神山まるごと高専 | 受験検討者向け紹介",
  description = "テクノロジー×デザインで人間の未来を変える学校。神山まるごと高専の学びと学校生活、入試情報への導線を1ページで紹介します。",
} = Astro.props;

const pageUrl = new URL(Astro.url.pathname, "https://syumai6842.github.io").toString();
const ogImage = "https://kamiyama.ac.jp/img/ogp.jpg";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="神山まるごと高専 紹介LP" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;500;700;800&family=Zen+Kaku+Gothic+New:wght@400;500;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
